<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ada Lovelace — The Enchantress of Numbers</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=Public+Sans:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#16233A;
    --ink-soft:#233650;
    --parchment:#F1E9D8;
    --parchment-dark:#E4D8BB;
    --brass:#A8823C;
    --brass-light:#C9A55C;
    --burgundy:#7A2E35;
    --burgundy-dark:#5E2129;
    --teal:#2E4A42;
    --teal-dark:#233A34;
    --charcoal:#241F1B;
    --cream-text:#F1E9D8;
  }

  *{box-sizing:border-box;}
  @media (prefers-reduced-motion: reduce){
    *{animation-duration:0.001ms !important; animation-iteration-count:1 !important; transition-duration:0.001ms !important;}
  }

  html{scroll-behavior:smooth;}

  body{
    margin:0;
    background:var(--parchment);
    color:var(--charcoal);
    font-family:'Public Sans', sans-serif;
    line-height:1.6;
  }

  h1,h2,h3{
    font-family:'Cormorant Garamond', serif;
    margin:0;
    font-weight:600;
  }

  .eyebrow{
    font-family:'Space Mono', monospace;
    letter-spacing:0.28em;
    text-transform:uppercase;
    font-size:0.72rem;
    font-weight:700;
  }

  a{color:inherit;}

  /* ---------- Punch-card signature strip ---------- */
  .punch-strip{
    display:flex;
    gap:6px;
    justify-content:center;
    padding:18px 20px;
    flex-wrap:wrap;
  }
  .punch-strip .bit{
    width:10px;
    height:10px;
    border-radius:2px;
    flex-shrink:0;
  }
  .punch-strip .bit.on{ background:var(--brass-light); box-shadow:0 0 6px rgba(201,165,92,0.5);}
  .punch-strip .bit.off{ background:rgba(241,233,216,0.12); border:1px solid rgba(241,233,216,0.25);}
  .punch-strip.on-parchment .bit.off{ background:rgba(36,31,27,0.06); border:1px solid rgba(36,31,27,0.18);}
  .punch-strip.on-parchment .bit.on{ background:var(--brass); box-shadow:none;}
  .punch-caption{
    text-align:center;
    font-family:'Space Mono', monospace;
    font-size:0.62rem;
    letter-spacing:0.2em;
    text-transform:uppercase;
    opacity:0.55;
    margin-top:-8px;
    padding-bottom:14px;
  }

  /* ---------- Hero ---------- */
  .hero{
    background:linear-gradient(180deg, var(--ink) 0%, var(--ink-soft) 100%);
    color:var(--cream-text);
    padding:76px 6vw 0;
  }
  .hero-inner{
    max-width:1180px;
    margin:0 auto;
    display:grid;
    grid-template-columns:1.15fr 0.85fr;
    gap:56px;
    align-items:center;
    padding-bottom:64px;
  }
  .hero-eyebrow{ color:var(--brass-light); opacity:0.9;}
  .hero h1{
    font-size:clamp(3rem, 7vw, 5.6rem);
    line-height:0.98;
    margin-top:18px;
    letter-spacing:-0.01em;
    animation:riseIn 900ms ease-out both;
  }
  .hero h1 em{
    font-style:italic;
    color:var(--brass-light);
  }
  .hero .tagline{
    font-family:'Space Mono', monospace;
    font-size:0.95rem;
    line-height:1.75;
    max-width:46ch;
    margin-top:26px;
    color:rgba(241,233,216,0.82);
    border-left:2px solid var(--brass);
    padding-left:18px;
    animation:riseIn 900ms 150ms ease-out both;
  }
  .hero .dates{
    margin-top:30px;
    font-family:'Space Mono', monospace;
    font-size:0.8rem;
    letter-spacing:0.15em;
    color:var(--brass-light);
  }

  .portrait-frame{
    position:relative;
    animation:riseIn 1000ms 100ms ease-out both;
  }
  .portrait-frame::before{
    content:"";
    position:absolute;
    inset:-14px;
    border:1px solid rgba(201,165,92,0.5);
    z-index:0;
  }
  .portrait-frame img{
    position:relative;
    z-index:1;
    display:block;
    width:100%;
    height:420px;
    object-fit:cover;
    object-position:top center;
    filter:sepia(12%) saturate(92%);
    box-shadow:0 30px 60px -20px rgba(0,0,0,0.6);
  }
  .portrait-caption{
    font-family:'Space Mono', monospace;
    font-size:0.65rem;
    letter-spacing:0.08em;
    color:rgba(241,233,216,0.55);
    margin-top:14px;
    text-align:right;
  }

  @keyframes riseIn{
    from{ opacity:0; transform:translateY(18px); }
    to{ opacity:1; transform:translateY(0); }
  }

  /* ---------- Biography ---------- */
  .bio{
    padding:96px 6vw;
    background:var(--parchment);
  }
  .bio-inner{
    max-width:720px;
    margin:0 auto;
  }
  .section-head{ margin-bottom:44px; }
  .section-head .eyebrow{ color:var(--burgundy); }
  .section-head h2{
    font-size:clamp(2.1rem, 4vw, 2.9rem);
    margin-top:10px;
  }
  .bio p{
    font-size:1.09rem;
    color:#3a332c;
    margin:0 0 26px;
  }
  .bio p:first-of-type::first-letter{
    font-family:'Cormorant Garamond', serif;
    font-size:4.6rem;
    font-weight:600;
    float:left;
    line-height:0.8;
    margin:6px 10px 0 0;
    color:var(--burgundy);
  }
  .bio-rule{
    width:64px;
    height:2px;
    background:var(--brass);
    margin:38px 0;
    border:none;
  }

  /* ---------- Timeline / Notes ---------- */
  .notes{
    background:var(--teal);
    color:var(--cream-text);
    padding:96px 6vw;
  }
  .notes .section-head .eyebrow{ color:var(--brass-light); }
  .notes-inner{ max-width:980px; margin:0 auto; }
  .note-list{
    list-style:none;
    margin:0;
    padding:0;
    display:grid;
    gap:2px;
    background:rgba(241,233,216,0.12);
    border:1px solid rgba(241,233,216,0.18);
  }
  .note-item{
    background:var(--teal-dark);
    padding:26px 28px;
    display:grid;
    grid-template-columns:64px 90px 1fr;
    gap:22px;
    align-items:start;
    transition:background 220ms ease, transform 220ms ease;
  }
  .note-item:hover{
    background:#1c302b;
    transform:translateX(4px);
  }
  .note-tag{
    font-family:'Space Mono', monospace;
    font-size:0.95rem;
    color:var(--brass-light);
    letter-spacing:0.05em;
  }
  .note-year{
    font-family:'Space Mono', monospace;
    font-size:0.82rem;
    color:rgba(241,233,216,0.6);
    padding-top:3px;
  }
  .note-body h3{
    font-size:1.28rem;
    margin-bottom:6px;
    font-weight:500;
  }
  .note-body p{
    margin:0;
    font-size:0.96rem;
    color:rgba(241,233,216,0.78);
  }

  /* ---------- Quote ---------- */
  .quote-band{
    background:linear-gradient(160deg, var(--burgundy) 0%, var(--burgundy-dark) 100%);
    color:var(--cream-text);
    padding:110px 6vw;
    text-align:center;
    position:relative;
    overflow:hidden;
  }
  .quote-mark{
    font-family:'Cormorant Garamond', serif;
    font-size:7rem;
    line-height:1;
    color:rgba(241,233,216,0.25);
    display:block;
    margin-bottom:-20px;
  }
  blockquote{
    margin:0 auto;
    max-width:760px;
    font-family:'Cormorant Garamond', serif;
    font-style:italic;
    font-size:clamp(1.6rem, 3.4vw, 2.5rem);
    line-height:1.35;
    font-weight:500;
  }
  .quote-attr{
    margin-top:26px;
    font-family:'Space Mono', monospace;
    font-size:0.78rem;
    letter-spacing:0.2em;
    text-transform:uppercase;
    color:var(--brass-light);
  }

  /* ---------- Footer ---------- */
  footer{
    background:var(--ink);
    color:rgba(241,233,216,0.6);
    text-align:center;
    padding-top:36px;
  }
  footer .credit{
    font-family:'Space Mono', monospace;
    font-size:0.72rem;
    letter-spacing:0.08em;
    padding:0 20px 34px;
  }
  footer .credit a{ color:var(--brass-light); text-decoration:none; border-bottom:1px dotted rgba(201,165,92,0.5);}

  /* ---------- Responsive ---------- */
  @media (max-width: 860px){
    .hero-inner{ grid-template-columns:1fr; gap:40px; padding-bottom:48px;}
    .portrait-frame img{ height:340px; }
    .note-item{ grid-template-columns:1fr; gap:8px; }
    .note-year{ padding-top:0; }
    .bio, .notes{ padding:72px 6vw; }
    .quote-band{ padding:80px 6vw; }
  }
  @media (max-width: 480px){
    .hero{ padding-top:56px; }
    .punch-strip .bit{ width:8px; height:8px; }
  }
</style>
